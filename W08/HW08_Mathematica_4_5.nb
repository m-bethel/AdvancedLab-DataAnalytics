          RowBox[{"5", " ", 
           RowBox[{"Tan", "[", "\[Theta]", "]"}]}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0"}], "}"}]}], "}"}], "]"}], ",", 
     RowBox[{"(*", 
      RowBox[{"Draw", " ", "the", " ", "Cart", " ", 
       RowBox[{"(", 
        RowBox[{"rotated", " ", "to", " ", "match", " ", "incline"}], ")"}]}],
       "*)"}], 
     RowBox[{"Rotate", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"EdgeForm", "[", "Black", "]"}], ",", 
         RowBox[{"GrayLevel", "[", "0.8", "]"}], ",", 
         RowBox[{"Rectangle", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"2", ",", "0"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"3.5", ",", "0.8"}], "}"}]}], "]"}], ",", "Black"}], 
        "}"}], ",", "\[Theta]", ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0"}], "}"}]}], "]"}], ",", 
     RowBox[{"(*", 
      RowBox[{"Force", " ", "Vectors", " ", 
       RowBox[{"(", 
        RowBox[{
        "originating", " ", "from", " ", "center", " ", "of", " ", "mass"}], 
        ")"}]}], "*)"}], 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Thickness", "[", "0.005", "]"}], ",", "Blue", ",", 
       RowBox[{"Arrowheads", "[", "0.03", "]"}], ",", 
       RowBox[{"(*", 
        RowBox[{"Center", " ", "of", " ", "mass", " ", "position"}], "*)"}], 
       RowBox[{"With", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"com", "=", 
           RowBox[{
            RowBox[{"RotationTransform", "[", 
             RowBox[{"\[Theta]", ",", 
              RowBox[{"{", 
               RowBox[{"0", ",", "0"}], "}"}]}], "]"}], "[", 
            RowBox[{"{", 
             RowBox[{"2.75", ",", "0.4"}], "}"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"(*", 
           RowBox[{"Gravity", ":", "mg"}], "*)"}], 
          RowBox[{"Red", ",", 
           RowBox[{"Arrow", "[", 
            RowBox[{"{", 
             RowBox[{"com", ",", 
              RowBox[{"com", "+", 
               RowBox[{"{", 
                RowBox[{"0", ",", 
                 RowBox[{"-", "1.5"}]}], "}"}]}]}], "}"}], "]"}], ",", 
           RowBox[{"Text", "[", 
            RowBox[{
             RowBox[{"Style", "[", 
              RowBox[{"\"\<mg\>\"", ",", "14", ",", "Bold"}], "]"}], ",", 
             RowBox[{"com", "+", 
              RowBox[{"{", 
               RowBox[{"0.3", ",", 
                RowBox[{"-", "1.2"}]}], "}"}]}]}], "]"}], ",", 
           RowBox[{"(*", 
            RowBox[{"Normal", " ", 
             RowBox[{"Force", ":", "N"}]}], "*)"}], "Blue", ",", 
           RowBox[{"Arrow", "[", 
            RowBox[{"{", 
             RowBox[{"com", ",", 
              RowBox[{"com", "+", 
               RowBox[{
                RowBox[{"RotationTransform", "[", 
                 RowBox[{
                  RowBox[{"\[Theta]", "+", 
                   RowBox[{"90", " ", "Degree"}]}], ",", 
                  RowBox[{"{", 
                   RowBox[{"0", ",", "0"}], "}"}]}], "]"}], "[", 
                RowBox[{"{", 
                 RowBox[{"1.2", ",", "0"}], "}"}], "]"}]}]}], "}"}], "]"}], 
           ",", 
           RowBox[{"Text", "[", 
            RowBox[{
             RowBox[{"Style", "[", 
              RowBox[{"\"\<N\>\"", ",", "14", ",", "Bold"}], "]"}], ",", 
             RowBox[{"com", "+", 
              RowBox[{
               RowBox[{"RotationTransform", "[", 
                RowBox[{
                 RowBox[{"\[Theta]", "+", 
                  RowBox[{"90", " ", "Degree"}]}], ",", 
                 RowBox[{"{", 
                  RowBox[{"0", ",", "0"}], "}"}]}], "]"}], "[", 
               RowBox[{"{", 
                RowBox[{"1.5", ",", "0"}], "}"}], "]"}]}]}], "]"}], ",", 
           RowBox[{"(*", 
            RowBox[{"Friction", " ", 
             RowBox[{"Force", ":", "f"}]}], "*)"}], 
           RowBox[{"Darker", "[", "Green", "]"}], ",", 
           RowBox[{"Arrow", "[", 
            RowBox[{"{", 
             RowBox[{"com", ",", 
              RowBox[{"com", "+", 
               RowBox[{
                RowBox[{"RotationTransform", "[", 
                 RowBox[{
                  RowBox[{"\[Theta]", "+", 
                   RowBox[{"180", " ", "Degree"}]}], ",", 
                  RowBox[{"{", 
                   RowBox[{"0", ",", "0"}], "}"}]}], "]"}], "[", 
                RowBox[{"{", 
                 RowBox[{"1.0", ",", "0"}], "}"}], "]"}]}]}], "}"}], "]"}], 
           ",", 
           RowBox[{"Text", "[", 
            RowBox[{
             RowBox[{"Style", "[", 
              RowBox[{"\"\<f\>\"", ",", "14", ",", "Bold"}], "]"}], ",", 
             RowBox[{"com", "+", 
              RowBox[{
               RowBox[{"RotationTransform", "[", 
                RowBox[{
                 RowBox[{"\[Theta]", "+", 
                  RowBox[{"180", " ", "Degree"}]}], ",", 
                 RowBox[{"{", 
                  RowBox[{"0", ",", "0"}], "}"}]}], "]"}], "[", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"-", "1.2"}], ",", "0"}], "}"}], "]"}]}]}], "]"}]}], 
          "}"}]}], "]"}]}], "}"}], ",", 
     RowBox[{"(*", 
      RowBox[{"Angle", " ", "Theta"}], "*)"}], 
     RowBox[{"Circle", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", "0"}], "}"}], ",", "1", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"2", "*", "\[Theta]"}], ",", "0"}], "}"}]}], "]"}], ",", 
     RowBox[{"Text", "[", 
      RowBox[{
       RowBox[{"Style", "[", 
        RowBox[{"\"\<\[Theta]\>\"", ",", "16"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"1.3", ",", "0.25"}], "}"}]}], "]"}], ",", 
