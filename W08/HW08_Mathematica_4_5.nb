Cell[BoxData[
 RowBox[{"Graphics", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"(*", 
     RowBox[{"Define", " ", "the", " ", "incline", " ", "angle"}], "*)"}], 
    RowBox[{
     RowBox[{
      RowBox[{"\[Theta]", "=", 
       RowBox[{"30", " ", "Degree"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"Draw", " ", "the", " ", "Inclined", " ", "Plane"}], "*)"}], 
      RowBox[{"Thickness", "[", "0.004", "]"}]}], ",", 
     RowBox[{"Line", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", "0"}], "}"}], ",", 
        RowBox[{"{", 
