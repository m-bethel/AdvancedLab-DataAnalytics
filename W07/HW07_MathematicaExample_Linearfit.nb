6e8018c1f9a2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "Constants", "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"L", "=", "12.5"}], ";", 
    RowBox[{"h", "=", "0.08"}], ";", 
    RowBox[{"g", "=", "9.80665"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"predictedS", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"5", "/", "14"}], ")"}], "*", "g", "*", 
      RowBox[{"(", 
       RowBox[{"h", "/", "L"}], ")"}], "*", "100"}]}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"cm", "/", 
     RowBox[{"s", "^", "2"}]}], "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", "Data", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"x5", "=", 
     RowBox[{"{", 
      RowBox[{
      "20.0", ",", "40.0", ",", "60.0", ",", "80.0", ",", "100.0", ",", 
       "120.0"}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"t5", "=", 
     RowBox[{"{", 
      RowBox[{
      "0.95", ",", "1.30", ",", "1.67", ",", "1.85", ",", "2.14", ",", 
       "2.30"}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"data5", "=", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"t5", "^", "2"}], ",", "x5"}], "}"}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Linear", " ", 
      RowBox[{"Model", ":", "x"}]}], "=", 
     RowBox[{
      RowBox[{"S", "*", 
       RowBox[{"t", "^", "2"}]}], "+", "b"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lm5", "=", 
     RowBox[{"LinearModelFit", "[", 
      RowBox[{"data5", ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", "tSq"}], "}"}], ",", "tSq"}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", "Assessment", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Predicted Slope: \>\"", ",", "predictedS"}], "]"}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Measured Slope: \>\"", ",", 
      RowBox[{
       RowBox[{"lm5", "[", "\"\<BestFitParameters\>\"", "]"}], "[", 
       RowBox[{"[", "2", "]"}], "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Intercept P-Value: \>\"", ",", 
      RowBox[{
       RowBox[{"lm5", "[", "\"\<ParameterPValues\>\"", "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], "]"}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", "Visualize", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{"ListPlot", "[", 
      RowBox[{"data5", ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"PointSize", "[", "0.02", "]"}], ",", "Black"}], "}"}]}]}], 
      "]"}], ",", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"lm5", "[", "tSq", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"tSq", ",", "0", ",", "6"}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", "Blue"}]}], "]"}], ",", 
     RowBox[{"Frame", "->", "True"}], ",", 
     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<t^2 (s^2)\>\"", ",", "\"\<x (cm)\>\""}], "}"}]}]}], 
    "]"}]}]}]], "Input",
