 RowBox[{
  RowBox[{"x", "=", 
   RowBox[{"{", 
    RowBox[{"1.00", ",", "2.00", ",", "3.00", ",", "4.00", ",", "5.00"}], 
    "}"}]}], ";", 
  RowBox[{"dx", "=", "0.02"}], ";", 
  RowBox[{"y", "=", 
   RowBox[{"{", 
    RowBox[{"2.8", ",", "4.7", ",", "7.1", ",", "9.4", ",", "10.8"}], "}"}]}],
   ";", 
  RowBox[{"dy", "=", "0.2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"a1", "=", "1.95"}], ";", " ", 
  RowBox[{"a0", "=", "1.15"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"da0", "=", "0.3"}], ";", " ", 
  RowBox[{"da1", "=", "0.1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"sigma", "[", "i_", "]"}], ":=", " ", 
   RowBox[{"Sqrt", "[", 
    RowBox[{
     SuperscriptBox["dy", "2"], "+", " ", 
     SuperscriptBox["da0", "2"], "+", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"a1", "*", "dx"}], ")"}], "2"], "+", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"x", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "*", "da1"}], ")"}], "2"]}], "]"}]}],
   ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Sum", "[", 
   RowBox[{
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"y", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "-", 
        RowBox[{"(", 
         RowBox[{"a0", "+", 
          RowBox[{"a1", "*", 
           RowBox[{"x", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}]}], ")"}]}], ")"}], "2"], "/", 
     SuperscriptBox[
      RowBox[{"sigma", "[", 
       RowBox[{"[", "i", "]"}], "]"}], "2"]}], ",", 
    RowBox[{"{", 
     RowBox[{"i", ",", "1", ",", "5"}], "}"}]}], "]"}], "//", "N"}]}], "Input",
