Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "1.", " ", "Clear", " ", "variables", " ", "to", " ", "avoid", " ", 
    "conflicts"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"Clear", "[", 
     RowBox[{
     "x", ",", "a", ",", "mu", ",", "sigma", ",", "xData", ",", "yData", ",", 
      "data", ",", "nlp", ",", "model"}], "]"}], ";"}], "\[IndentingNewLine]",
    "\n", 
   RowBox[{"(*", 
    RowBox[{"2.", " ", "Define", " ", "the", " ", "data"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"xData", "=", 
     RowBox[{"{", 
      RowBox[{
      "5.0", ",", "5.4", ",", "5.8", ",", "6.2", ",", "6.6", ",", "7.0", ",", 
       "7.4", ",", "7.8", ",", "8.2", ",", "8.6", ",", "9.0", ",", "9.4", ",",
        "9.8", ",", "10.2"}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"yData", "=", 
     RowBox[{"{", 
      RowBox[{
      "0.22", ",", "0.82", ",", "2.10", ",", "4.35", ",", "7.56", ",", 
       "10.60", ",", "12.38", ",", "11.70", ",", "9.18", ",", "5.85", ",", 
       "3.11", ",", "1.35", ",", "0.44", ",", "0.15"}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"data", "=", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"xData", ",", "yData"}], "}"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "3.", " ", "Define", " ", "the", " ", "model", " ", "and", " ", "perform",
      " ", "the", " ", "fit"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"model", "=", 
     RowBox[{"a", "*", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"x", "-", "mu"}], ")"}], "^", "2"}]}], "/", 
        RowBox[{"(", 
         RowBox[{"2", "*", 
          RowBox[{"sigma", "^", "2"}]}], ")"}]}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "We", " ", "provide", " ", "explicit", " ", "starting", " ", "values", 
     " ", "to", " ", "help", " ", "the", " ", "solver"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"nlp", "=", 
     RowBox[{"NonlinearModelFit", "[", 
      RowBox[{"data", ",", 
       RowBox[{"{", 
        RowBox[{"model", ",", 
         RowBox[{"sigma", ">", "0"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"a", ",", "12"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"mu", ",", "7.5"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"sigma", ",", "1"}], "}"}]}], "}"}], ",", "x"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"4.", " ", "Output", " ", "the", " ", "results"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Best Fit Parameters: \>\"", ",", 
      RowBox[{"nlp", "[", "\"\<BestFitParameters\>\"", "]"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"5.", " ", "Visualize"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{"ListPlot", "[", 
      RowBox[{"data", ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Red", ",", 
          RowBox[{"PointSize", "[", "Large", "]"}]}], "}"}]}], ",", 
       RowBox[{"PlotLabel", "->", "\"\<Gaussian Fit Results\>\""}]}], "]"}], 
     ",", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"nlp", "[", "x", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "5", ",", "10.5"}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", "Blue"}]}], "]"}], ",", 
     RowBox[{"Frame", "->", "True"}], ",", 
     RowBox[{"Axes", "->", "False"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9816588277463846`*^9, 3.98165882774706*^9}},
 CellLabel->
  "In[133]:=",ExpressionUUID->"b30f9af7-98da-47c8-9c32-ba662938c776"],

