Cell[CellGroupData[{

Cell["Problem 5.", "Subsubsection",
 CellChangeTimes->{{3.981658903611633*^9, 
  3.9816589081267004`*^9}},ExpressionUUID->"c4167e73-4592-4d64-bb8e-\
6a1d9555925e"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Clear", "[", 
    RowBox[{
    "t", ",", "counts", ",", "data", ",", "model", ",", "nlp", ",", "N0", ",",
      "lambda", ",", "bkg"}], "]"}], ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
   "Time", " ", "intervals", " ", "from", " ", "0.5", " ", "to", " ", "20", 
    " ", "in", " ", "steps", " ", "of", " ", "0.5"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"tData", "=", 
    RowBox[{"Range", "[", 
     RowBox[{"0.5", ",", "20.0", ",", "0.5"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"Count", " ", "data", " ", "from", " ", "the", " ", "image"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"counts", "=", 
    RowBox[{"{", 
     RowBox[{
     "816", ",", "733", ",", "660", ",", "593", ",", "539", ",", "498", ",", 
      "440", ",", "407", ",", "374", ",", "334", ",", "312", ",", "279", ",", 
      "250", ",", "237", ",", "218", ",", "187", ",", "179", ",", "168", ",", 
      "163", ",", "144", ",", "142", ",", "127", ",", "117", ",", "118", ",", 
      "108", ",", "98", ",", "85", ",", "86", ",", "90", ",", "81", ",", "74",
       ",", "71", ",", "73", ",", "57", ",", "56", ",", "56", ",", "62", ",", 
      "58", ",", "62", ",", "61"}], "}"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"data", "=", 
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{"tData", ",", "counts"}], "}"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"model", "=", 
    RowBox[{
     RowBox[{"n0", "*", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "lambda"}], "*", "t"}], "]"}]}], "+", "bkg"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"nlp", "=", 
    RowBox[{"NonlinearModelFit", "[", 
     RowBox[{"data", ",", "model", ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"n0", ",", "900"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"lambda", ",", "0.1"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"bkg", ",", "60"}], "}"}]}], "}"}], ",", "t"}], "]"}]}], 
   ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Extract", " ", "the", " ", "results"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"nlp", "[", "\"\<BestFitParameters\>\"", 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"ListPlot", "[", 
    RowBox[{"data", ",", 
     RowBox[{"PlotStyle", "->", "Red"}], ",", 
     RowBox[{"PlotLabel", "->", "\"\<Radioactive Decay Fit\>\""}]}], "]"}], 
   ",", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"nlp", "[", "t", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "20"}], "}"}], ",", 
     RowBox[{"PlotStyle", "->", "Blue"}]}], "]"}], ",", 
   RowBox[{"Frame", "->", "True"}], ",", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<Time (min)\>\"", ",", "\"\<Counts\>\""}], "}"}]}]}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Log", "[", "2", "]"}], "/", 
  RowBox[{"(", 
   RowBox[{"lambda", "/.", " ", 
    RowBox[{"nlp", "[", "\"\<BestFitParameters\>\"", "]"}]}], 
   ")"}]}]}], "Input",
 CellChangeTimes->{{3.9816589120773396`*^9, 3.9816589120793533`*^9}, {
  3.9816591053113585`*^9, 3.9816591423482056`*^9}},
